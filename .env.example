# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# soulchat-ai API base URL — the external-facing gateway (not InfluenceAI directly)
VITE_API_BASE_URL=http://localhost:8004/client/v1/influencer

# Your API key — issued by the platform team (use sk_dev_testkey for local testing)
VITE_API_KEY=sk_your_key_here
